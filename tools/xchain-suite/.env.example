# XChainJS Testing GUI - Environment Variables
# Copy this to .env and fill in your API keys

# EVM RPC Providers (optional - public RPCs used as fallback)
VITE_ANKR_API_KEY=
VITE_INFURA_API_KEY=
VITE_ALCHEMY_API_KEY=

# Block Explorers (optional - improves rate limits)
VITE_ETHERSCAN_API_KEY=
VITE_BSCSCAN_API_KEY=
VITE_SNOWTRACE_API_KEY=
VITE_ARBISCAN_API_KEY=

# UTXO Providers (optional)
VITE_BLOCKCYPHER_API_KEY=
VITE_SOCHAIN_API_KEY=

# Solana (optional - public RPC is rate-limited, get a key from helius.dev)
VITE_SOL_API_KEY=

# Chainflip (optional - enables broker + affiliate fees)
VITE_ASGARDEX_BROKER_URL=
VITE_ASGARDEX_AFFILIATE_BROKERS_ADDRESS=

# Other
VITE_COVALENT_API_KEY=
