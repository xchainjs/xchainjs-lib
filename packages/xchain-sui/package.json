{
  "name": "@xchainjs/xchain-sui",
  "version": "0.1.0",
  "description": "Sui client for XChainJS",
  "keywords": [
    "Sui",
    "XChain"
  ],
  "author": "THORChain",
  "homepage": "https://github.com/xchainjs/xchainjs-lib",
  "license": "MIT",
  "main": "lib/index.js",
  "module": "lib/index.esm.js",
  "typings": "lib/index.d.ts",
  "directories": {
    "lib": "lib",
    "test": "__tests__"
  },
  "files": [
    "lib"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:xchainjs/xchainjs-lib.git"
  },
  "scripts": {
    "clean": "rm -rf .turbo && rm -rf lib",
    "build": "yarn clean && rollup -c --bundleConfigAsCjs",
    "build:release": "yarn exec rm -rf release && yarn pack && yarn exec \"mkdir release && tar zxvf package.tgz --directory release && rm package.tgz\"",
    "test": "jest",
    "lint": "eslint --config ../../eslint.config.mjs \"{src,__tests__}/**/*.ts\" --fix --max-warnings 0"
  },
  "dependencies": {
    "@mysten/sui": "^1.21.0",
    "@xchainjs/xchain-client": "workspace:*",
    "@xchainjs/xchain-crypto": "workspace:*",
    "@xchainjs/xchain-util": "workspace:*",
    "micro-key-producer": "^0.7.6"
  },
  "publishConfig": {
    "access": "public",
    "directory": "release/package"
  }
}
